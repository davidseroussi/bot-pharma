# Token brut uniquement, sans le nom du cookie.
OCP_AUTH_PHARMACIEN=eyJ...

# Alternative si Imperva demande un header cookie complet.
# OCP_COOKIE=visid_incap_...; nlbi_...; ocp-auth-pharmacien=eyJ...

# Email notification. For AWS SES, SMTP_USER is not an email address, so set
# EMAIL_FROM or MAIL_FROM to a verified sender such as new@voicestars.co.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=1
SMTP_USER=you@example.com
SMTP_PASSWORD=app-password
EMAIL_FROM=you@example.com
MAIL_FROM=you@example.com
EMAIL_TO=you@example.com
